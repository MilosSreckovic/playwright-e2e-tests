{
  "name": "playwright-e2e-tests",
  "version": "1.0.0",
  "description": "Playwright E2E tests with AI capabilities including MCP",
  "keywords": [
    "playwright",
    "playwright-e2e-tests",
    "playwright-mcp"
  ],
  "license": "ISC",
  "author": "Milos Sreckovic",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "demo": "npx playwright test tests/demo/mytest.spec.ts --headed",
    "login": "npx playwright test tests/functional/login.spec.ts --headed",
    "make-appt": "npx playwright test tests/functional/make.apptmnt.spec.ts --headed",
    "ele-int": "npx playwright test tests/demo/element.handle.make.apptmnt.spec.ts --headed",
    "inv": "npx playwright test tests/functional/inventory.spec.ts --headed",
    "debug-test": "npx playwright test tests/demo/debug.make.apptmnt.spec.ts --headed",
    "debug-way-ui": "npx playwright test tests/demo/debug.make.apptmnt.spec.ts --ui --headed",
    "debug-way-cli": "PWDEBUG=1 npx playwright test tests/demo/debug.make.apptmnt.spec.ts",
    "debug-way-trace": "npx playwright test tests/demo/debug.make.apptmnt.spec.ts --trace on",
    "pw-basic-cap": "npx playwright test tests/demo/pw.basic.capabilities.ts --headed",
    "pw-basic-cap:tag": "npx playwright test --grep=\"@smoke\" --headed",
    "pw-adv-cap": "npx playwright test tests/demo/pw.adv.capabilities.spec.ts --headed",
    "user-api": "npx playwright test tests/api/user.api.spec.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "dotenv": "~17.4.2"
  },
  "dependencies": {
    "chalk": "^5.6.2"
  }
}
